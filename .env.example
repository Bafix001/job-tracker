# Example .env (DO NOT commit this file)
# Database
POSTGRES_DB=jobtrackerdb
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# Spring datasource (optional, falls back to POSTGRES values)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/jobtrackerdb
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=admin123

# JWT secret (change to a secure random value)
APP_JWT_SECRET=changeme-replace-with-secure-random

# Server port
SERVER_PORT=8080
